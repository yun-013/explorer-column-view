<Window x:Class="ColumnView.QuickLookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ShowActivated="False" ResizeMode="NoResize"
        Topmost="True" SnapsToDevicePixels="True" UseLayoutRounding="True"
        WindowStartupLocation="Manual"
        PreviewKeyDown="QuickLookWindow_PreviewKeyDown">

    <Window.Resources>
        <!-- シークバーのトラック (再生済み / 未再生)。当たり判定は全高、見た目は細いバーだけ。
             高さ 3 + 半径 1.5 で左右端が完全な半円になる (継ぎ目はつまみが覆う) -->
        <Style x:Key="SeekTrackButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Grid Background="Transparent">
                            <Border Height="3" CornerRadius="1.5" VerticalAlignment="Center"
                                    Background="{TemplateBinding Background}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 再生バーのアイコンボタン (再生/一時停止): 丸いハイライトでホバー -->
        <Style x:Key="BarIconButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2EFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- つまみ: 普段は控えめな小さい円、ホバー/ドラッグ中は少し大きくなる -->
        <Style x:Key="SeekThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Ellipse x:Name="Dot" Width="10" Height="10" Fill="White">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Width" Value="13"/>
                                <Setter TargetName="Dot" Property="Height" Value="13"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Dot" Property="Width" Value="13"/>
                                <Setter TargetName="Dot" Property="Height" Value="13"/>
                                <Setter TargetName="Dot" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- シークバー本体。再生済み側はアクセントカラー、残りは薄い白 -->
        <Style x:Key="SeekSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <!-- クリック時のジャンプはコード側 (Seek_PreviewMouseLeftButtonDown) で
                             位置から直接計算する。LargeChange コマンドだと 1 秒しか動かない -->
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SeekTrackButton}"
                                              Background="{DynamicResource AccentBrush}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SeekTrackButton}"
                                              Background="#40FFFFFF"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SeekThumbStyle}"/>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 影のための余白。中身だけを角丸で見せる (タイトルバー・枠は一切なし) -->
    <Border x:Name="Card" Margin="18" CornerRadius="12"
            Background="{DynamicResource SurfaceBrush}"
            SnapsToDevicePixels="True" SizeChanged="Card_SizeChanged"
            MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.32" Color="Black"/>
        </Border.Effect>

        <Grid x:Name="Host" ClipToBounds="True">
            <!-- 画像 / シェルの大サムネイル (フォールバック) -->
            <Image x:Name="ImageView" Stretch="Uniform" Visibility="Collapsed"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- テキスト / コード -->
            <ScrollViewer x:Name="TextScroll" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto" Padding="18,14">
                <TextBlock x:Name="TextView" FontFamily="Consolas, ui-monospace, monospace"
                           FontSize="12.5" TextWrapping="NoWrap"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </ScrollViewer>

            <!-- Markdown (整形表示) -->
            <FlowDocumentScrollViewer x:Name="DocView" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Focusable="False"
                                      Foreground="{DynamicResource TextPrimaryBrush}"/>

            <!-- PDF (ページを画像にレンダリングして縦に並べる) -->
            <ScrollViewer x:Name="PdfScroll" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="10">
                <StackPanel x:Name="PdfPages"/>
            </ScrollViewer>

            <!-- 動画 / 音声 -->
            <MediaElement x:Name="MediaView" Visibility="Collapsed"
                          LoadedBehavior="Manual" UnloadedBehavior="Stop"
                          Stretch="Uniform" ScrubbingEnabled="True"
                          MediaOpened="MediaView_MediaOpened"
                          MediaEnded="MediaView_MediaEnded"
                          MediaFailed="MediaView_MediaFailed"/>

            <!-- 音声のときの見出し (中身が真っ黒にならないように) -->
            <StackPanel x:Name="AudioGlyph" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock FontFamily="{StaticResource IconFont}" FontSize="72"
                           Text="&#xE8D6;" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="AudioName" Margin="0,14,0,0" FontSize="14"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                           MaxWidth="360" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>

            <!-- ホバー時だけ現れる操作バー (動画・音声のシーク)。左右端が完全な丸のピル型 -->
            <Border x:Name="MediaBar" VerticalAlignment="Bottom" Visibility="Collapsed"
                    Opacity="0" CornerRadius="18" Margin="12" Padding="10,4"
                    Background="#CC1A1A1A">
                <DockPanel LastChildFill="True">
                    <Button x:Name="PlayPause" DockPanel.Dock="Left"
                            Style="{StaticResource BarIconButton}"
                            Click="PlayPause_Click" Content="&#xE769;"/>
                    <TextBlock x:Name="TimeText" DockPanel.Dock="Right" Foreground="White"
                               VerticalAlignment="Center" Margin="10,0,2,0" FontSize="11.5"
                               Text="0:00 / 0:00"/>
                    <Slider x:Name="Seek" Style="{StaticResource SeekSliderStyle}"
                            VerticalAlignment="Center" Margin="10,0"
                            Minimum="0" Maximum="1"
                            Thumb.DragStarted="Seek_DragStarted"
                            Thumb.DragCompleted="Seek_DragCompleted"
                            PreviewMouseLeftButtonDown="Seek_PreviewMouseLeftButtonDown"/>
                </DockPanel>
            </Border>

            <!-- ホバー時だけ現れる閉じるボタン (唯一の装飾)。 -->
            <Button x:Name="CloseButton" Width="28" Height="28" Margin="10"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Opacity="0" IsHitTestVisible="False" Cursor="Hand"
                    Click="CloseButton_Click" FontFamily="{StaticResource IconFont}"
                    FontSize="10" Content="&#xE8BB;">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#CC1A1A1A" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFE0553F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
