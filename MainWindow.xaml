<Window x:Class="ColumnView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ColumnView"
        Title="Column View"
        Height="680" Width="1180"
        MinHeight="340" MinWidth="520"
        FontFamily="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}" FontSize="13"
        Background="{DynamicResource WindowBackgroundBrush}"
        StateChanged="Window_StateChanged"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseMove="Window_PreviewMouseMove">

    <!-- WindowStyle は既定 (SingleBorderWindow) のまま WindowChrome で標準枠を消す。
         WindowStyle=None にすると WS_CAPTION が外れ、DWM の最大化/最小化アニメーションが効かなくなる -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="10"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>

        <!-- ツールバーのアイコンボタン -->
        <Style x:Key="ToolButton" TargetType="ButtonBase">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PressedOverlayBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleToolButton" TargetType="ToggleButton" BasedOn="{StaticResource ToolButton}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentFocusBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- お気に入り: 未登録=白抜き星 / 登録済み=アクセント色の塗り星 -->
        <Style x:Key="FavoriteToggle" TargetType="ToggleButton" BasedOn="{StaticResource ToggleToolButton}">
            <Setter Property="Content" Value="&#xE734;"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="&#xE735;"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- キャプション (最小化/最大化/閉じる) ボタン: それぞれ独立した角丸チップに。
             ホバー色はテンプレート内ではなくスタイル側で切り替える (閉じるだけ赤に上書きするため) -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE0553F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- タブ (ブラウザー風) -->
        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="2,6,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="10,10,0,0" Background="Transparent"
                                    Padding="11,7" MinWidth="130" MaxWidth="220">
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right" Width="18" Height="18" Margin="6,0,0,0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            FontFamily="{StaticResource IconFont}" FontSize="9" Content="&#xE711;"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            ToolTip="タブを閉じる (Ctrl+W)"
                                            Click="CloseTab_Click" Tag="{Binding}"/>
                                    <TextBlock x:Name="TabTitle" Text="{Binding Title}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </Border>
                            <!-- 非アクティブタブ同士の区切り線 (Files 風) -->
                            <Border x:Name="Sep" Width="1" Height="14" Background="{DynamicResource WindowOuterBorderBrush}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <!-- アクティブタブの「すそ野」: 付け根が外側へなだらかに広がる凹みの丸み (Chrome/Files 風) -->
                            <Path x:Name="FlareL" Width="8" Height="8" Stretch="None" Visibility="Collapsed"
                                  HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-8,0,0,0"
                                  Fill="{DynamicResource WindowBackgroundBrush}"
                                  Data="M 8,0 A 8,8 0 0 1 0,8 L 8,8 Z"/>
                            <Path x:Name="FlareR" Width="8" Height="8" Stretch="None" Visibility="Collapsed"
                                  HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-8,0"
                                  Fill="{DynamicResource WindowBackgroundBrush}"
                                  Data="M 0,0 A 8,8 0 0 0 8,8 L 0,8 Z"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabHoverBrush}"/>
                                <Setter TargetName="Sep" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="TabTitle" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <!-- アクティブタブは下のウィンドウ背景と同色にして繋げ、文字を濃く・太くして際立たせる -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
                                <Setter TargetName="Sep" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="TabTitle" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="TabTitle" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="FlareL" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="FlareR" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- すそ野が隣のタブの描画に覆われないよう、アクティブタブを手前に -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Panel.ZIndex" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 通常のファイル / フォルダ行 (ホーム列のお気に入り・グループメンバーも含む) -->
        <DataTemplate x:Key="FileItemTemplate" DataType="{x:Type local:FileSystemItem}">
            <Grid ToolTipService.ShowDuration="30000"
                  ToolTipOpening="Item_ToolTipOpening"
                  ToolTipClosing="Item_ToolTipClosing">
                <Grid.ToolTip>
                    <ToolTip MaxWidth="420">
                        <Grid Margin="3,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.Resources>
                                <Style TargetType="TextBlock" x:Key="Label">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="Margin" Value="0,1,12,1"/>
                                </Style>
                                <Style TargetType="TextBlock" x:Key="Value">
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </Grid.Resources>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名前" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Style="{StaticResource Value}"/>

                            <!-- 場所 (フルパス): 検索結果のみ。省略された場所をホバーで確認できる -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="場所" Style="{StaticResource Label}"
                                       Visibility="{Binding LocationVisibility}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ParentPath}" Style="{StaticResource Value}"
                                       Visibility="{Binding LocationVisibility}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="種類" Style="{StaticResource Label}"
                                       Visibility="{Binding TypeRowVisibility}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TypeName}" Style="{StaticResource Value}"
                                       Visibility="{Binding TypeRowVisibility}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="サイズ" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SizeText}" Style="{StaticResource Value}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="更新日時" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ModifiedText}" Style="{StaticResource Value}"/>

                            <!-- 寸法 (画像) / 長さ (動画・音声): ホバー時に取得 -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding MetaLabel}" Style="{StaticResource Label}"
                                       Visibility="{Binding MetaRowVisibility}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding MetaValue}" Style="{StaticResource Value}"
                                       Visibility="{Binding MetaRowVisibility}"/>

                            <!-- クラウド同期プロバイダ -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="同期" Style="{StaticResource Label}"
                                       Visibility="{Binding ProviderRowVisibility}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ProviderName}" Style="{StaticResource Value}"
                                       Visibility="{Binding ProviderRowVisibility}"/>
                        </Grid>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <!-- 切り取り済みは半透明 (エクスプローラーと同じ) -->
                            <DataTrigger Binding="{Binding ClipMark}" Value="Cut">
                                <Setter Property="Opacity" Value="0.45"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <!-- バッジ / シェブロンは Auto: 無い行では名前の表示幅に回す -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Width="24" Height="24"
                       Source="{Binding Icon}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                    <!-- 検索結果: 検索起点から見た場所 (サブフォルダ) を小さく添える -->
                    <TextBlock Text="{Binding Location}" FontSize="10.5"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0"
                               Visibility="{Binding LocationVisibility}"/>
                    <!-- ドライブの容量ゲージ (残量わずかで赤) -->
                    <ProgressBar Height="3" Margin="0,3,6,0" Minimum="0" Maximum="1"
                                 Value="{Binding DriveUsedRatio, Mode=OneWay}"
                                 Visibility="{Binding DriveGaugeVisibility}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid>
                                                <Border x:Name="PART_Track" Background="{DynamicResource BorderSoftBrush}" CornerRadius="1.5"/>
                                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                                        CornerRadius="1.5" HorizontalAlignment="Left"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLowSpace}" Value="True">
                                        <Setter Property="Foreground" Value="#FFD9534F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <TextBlock Text="{Binding DriveCapacityText}" FontSize="10.5"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,2,0,0" Visibility="{Binding DriveGaugeVisibility}"/>
                </StackPanel>
                <TextBlock Grid.Column="2" FontFamily="{StaticResource IconFont}" FontSize="11"
                           Text="{Binding Badge}" Foreground="{Binding BadgeBrush}"
                           Margin="4,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <!-- バッジ無しの行は Margin ごと畳んで幅を空ける -->
                                <DataTrigger Binding="{Binding Badge}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="3" FontFamily="{StaticResource IconFont}" FontSize="9"
                           Text="&#xE76C;" Foreground="{DynamicResource TextTertiaryBrush}"
                           Visibility="{Binding ChevronVisibility}"
                           Margin="4,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </DataTemplate>

        <!-- タブグループの見出し行 (クリックで中身を次の列に展開) -->
        <DataTemplate x:Key="GroupItemTemplate" DataType="{x:Type local:FileSystemItem}">
            <Grid Background="Transparent"
                  ToolTip="クリックで中身を開く / 右クリックで「すべてタブで開く」など管理">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontFamily="{StaticResource IconFont}" FontSize="14"
                           Text="&#xE71D;" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                           Margin="4,0,0,0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" Text="{Binding MemberCount}" Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="2,0,4,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" FontFamily="{StaticResource IconFont}" FontSize="9"
                           Text="&#xE76C;" Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </DataTemplate>

        <local:ColumnItemTemplateSelector x:Key="ColumnItemSelector"
                                          NormalTemplate="{StaticResource FileItemTemplate}"
                                          GroupTemplate="{StaticResource GroupItemTemplate}"/>

        <!-- パンくずの各セグメント -->
        <Style x:Key="CrumbButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentCrumbHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ソート基準のドロップダウン (ツールバーのアイコンボタンと揃えたフラットな見た目) -->
        <Style x:Key="SortComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChipHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChipPressedBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <DockPanel Margin="10,0,9,0" IsHitTestVisible="False">
                                <TextBlock DockPanel.Dock="Right" FontFamily="{StaticResource IconFont}" FontSize="8"
                                           Text="&#xE70D;" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"/>
                            </DockPanel>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Placement="Bottom" VerticalOffset="-2"
                                   PopupAnimation="Fade" StaysOpen="False">
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="4" Margin="6"
                                        Effect="{DynamicResource MenuShadow}"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ルート枠 (WindowChrome で標準枠を消しているため自前で薄い枠) -->
    <Border x:Name="RootBorder" Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource WindowOuterBorderBrush}" BorderThickness="1" CornerRadius="10">
        <DockPanel x:Name="RootDock">

            <!-- 最上段: タブ列 + キャプションボタン (Chrome 風) -->
            <Grid x:Name="CaptionBar" DockPanel.Dock="Top" Height="40" Background="{DynamicResource CaptionBarBrush}"
                  SizeChanged="CaptionBar_SizeChanged">
                <Grid.ColumnDefinitions>
                    <!-- タブが増えてもキャプションボタンを押し出さない (タブ側をクリップ) -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid x:Name="TabArea" Grid.Column="0" ClipToBounds="True">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <ListBox x:Name="TabStrip" ItemsSource="{Binding Tabs}" SelectedItem="{Binding ActiveTab}"
                             ItemContainerStyle="{StaticResource TabItemStyle}"
                             Background="Transparent" BorderThickness="0" Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.PanningMode="HorizontalOnly"
                             SelectionChanged="TabStrip_SelectionChanged"
                             PreviewMouseWheel="TabStrip_PreviewMouseWheel"
                             PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"
                             PreviewMouseLeftButtonUp="TabStrip_PreviewMouseLeftButtonUp">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- 左右 8px はアクティブタブのすそ野の逃げ場 (スクロール内容側に持たせ、端でクリップさせない) -->
                                <StackPanel Orientation="Horizontal" Margin="8,0"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <!-- 標準テンプレートは Border に Padding=1 が焼き込まれていて (Padding=0 でも消えない)、
                             タブが上下 1px 縮んで下端にキャプション色の線が出る。素の ScrollViewer に差し替えて根治 -->
                        <ListBox.Template>
                            <ControlTemplate TargetType="ListBox">
                                <ScrollViewer Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled"
                                              CanContentScroll="False">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ListBox.Template>
                    </ListBox>
                    <Button x:Name="NewTabButton" Style="{StaticResource ToolButton}" Width="32" Height="28" Margin="4,7,0,0"
                            VerticalAlignment="Top" Content="&#xE710;"
                            ToolTip="新しいタブ (Ctrl+T)" Click="NewTab_Click"/>
                </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Style="{StaticResource CaptionButton}" Content="&#xE921;"
                            ToolTip="最小化" Click="Minimize_Click"/>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Content="&#xE922;"
                            ToolTip="最大化" Click="Maximize_Click"/>
                    <Button Style="{StaticResource CaptionCloseButton}" Content="&#xE8BB;"
                            ToolTip="閉じる" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ツールバー: 独立した浮遊カード -->
            <Border x:Name="ToolbarCard" DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" Padding="7,7"
                    Margin="6,4,6,4" CornerRadius="12"
                    BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1"
                    Effect="{DynamicResource CardShadowBelow}"
                    SizeChanged="Toolbar_SizeChanged">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Content="&#xE72B;"
                            ToolTip="戻る (Alt+←)" IsEnabled="{Binding CanGoBack}" Click="Back_Click"/>
                    <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Content="&#xE72A;"
                            ToolTip="進む (Alt+→)" IsEnabled="{Binding CanGoForward}" Click="Forward_Click"/>
                    <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Content="&#xE70E;"
                            ToolTip="上へ (Alt+↑)" IsEnabled="{Binding CanGoUp}" Click="Up_Click"/>
                    <Border DockPanel.Dock="Left" Width="1" Background="{DynamicResource BorderSoftBrush}" Margin="5,3"/>

                    <!-- 右側のボタン群 -->
                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource FavoriteToggle}"
                                  ToolTip="現在のフォルダをお気に入りに追加 / 削除"
                                  IsChecked="{Binding IsCurrentFavorite, Mode=OneWay}" Click="Favorite_Click"/>
                    <Button x:Name="GroupsButton" DockPanel.Dock="Right" Style="{StaticResource ToolButton}"
                            Content="&#xE71D;" Foreground="{DynamicResource AccentBrush}"
                            ToolTip="タブグループ (よく使うフォルダの組合せをワンクリックで開く)"
                            Click="GroupsButton_Click"/>
                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleToolButton}" Content="&#xE7B3;"
                                  ToolTip="隠しファイルを表示 (Ctrl+H)" IsChecked="{Binding ShowHidden}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}"
                            ToolTip="昇順 / 降順の切り替え" Click="SortDirection_Click">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE74B;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SortDescending}" Value="False">
                                                <Setter Property="Text" Value="&#xE74A;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleToolButton}" Content="&#xE8B7;"
                                  ToolTip="フォルダを先頭にまとめる (オフ = ファイルと同列に並べる)"
                                  IsChecked="{Binding FoldersFirst}"/>
                    <ComboBox DockPanel.Dock="Right" Width="82" Height="28" Margin="2,0" FontSize="12"
                              Style="{StaticResource SortComboBox}" ToolTip="並べ替えの基準"
                              SelectedIndex="{Binding SortKeyIndex}">
                        <ComboBoxItem Content="名前"/>
                        <ComboBoxItem Content="更新日時"/>
                        <ComboBoxItem Content="サイズ"/>
                        <ComboBoxItem Content="種類"/>
                    </ComboBox>

                    <!-- 検索アイコン: ウィンドウが狭いときだけ表示 (クリックでボックス展開) -->
                    <Button x:Name="SearchToggleButton" DockPanel.Dock="Right" Style="{StaticResource ToolButton}"
                            Content="&#xE721;" Visibility="Collapsed"
                            ToolTip="検索 (Ctrl+F)" Click="SearchToggle_Click"/>

                    <!-- 検索ボックス: 現在のフォルダ以下を名前で検索 (Enter で実行) -->
                    <Border x:Name="SearchBorder" DockPanel.Dock="Right" Width="170" Height="32" Margin="2,0"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="10"
                            Effect="{DynamicResource SubtleShadow}">
                        <Grid>
                            <TextBlock FontFamily="{StaticResource IconFont}" FontSize="12" Text="&#xE721;"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="9,0,0,0"/>
                            <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     VerticalContentAlignment="Center" Padding="26,0,24,0"
                                     ToolTip="現在のフォルダ以下を検索 (Enter で実行 / Esc で閉じる。* ? のワイルドカード可)"
                                     KeyDown="SearchBox_KeyDown" LostKeyboardFocus="SearchBox_LostFocus"/>
                            <TextBlock Text="検索 (Ctrl+F)" IsHitTestVisible="False"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="28,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- 入力クリア (タブの閉じるボタンと同じ見た目) -->
                            <Button Width="18" Height="18" Margin="0,0,5,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    FontFamily="{StaticResource IconFont}" FontSize="9" Content="&#xE711;"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    ToolTip="クリア" Click="SearchClear_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- アドレスバー: カードの上にさらに浮かぶ入力欄 (二重シャドウ) -->
                    <Border x:Name="AddressBar" Margin="6,0" Height="32" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="10"
                            Effect="{DynamicResource SubtleShadow}"
                            MouseLeftButtonDown="AddressBar_MouseLeftButtonDown">
                        <Grid>
                            <DockPanel>
                                <DockPanel.Style>
                                    <Style TargetType="DockPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditingAddress}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DockPanel.Style>
                                <TextBlock DockPanel.Dock="Left" FontFamily="{StaticResource IconFont}" FontSize="13"
                                           Text="&#xE8B7;" Foreground="#FFE3A52E" Margin="8,0,2,0"
                                           VerticalAlignment="Center"/>
                                <!-- 深い階層では先頭ではなく末尾 (現在地) 側を見せる -->
                                <ScrollViewer x:Name="CrumbScroll" HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled" Focusable="False"
                                              VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding Breadcrumbs}" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:Crumb}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE76C;" FontFamily="{StaticResource IconFont}" FontSize="9"
                                                           Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="1,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFirst}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Button Style="{StaticResource CrumbButton}" Content="{Binding Display}"
                                                        Tag="{Binding}" Click="Crumb_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>

                            <TextBox x:Name="PathBox" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     Visibility="{Binding IsEditingAddress, Converter={StaticResource B2V}}"
                                     Text="{Binding CurrentPath, Mode=OneWay}"
                                     KeyDown="PathBox_KeyDown" LostKeyboardFocus="PathBox_LostFocus"/>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ステータスバー: 線で区切らず最背面 (ウィンドウ背景) にそのまま載せる -->
            <StatusBar DockPanel.Dock="Bottom" Background="Transparent" BorderThickness="0" Margin="8,0,8,2">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Space: プレビュー (Seer)   " Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE753;" Foreground="SteelBlue" VerticalAlignment="Center"/>
                        <TextBlock Text=" オンラインのみ  " Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE73E;" Foreground="SeaGreen" VerticalAlignment="Center"/>
                        <TextBlock Text=" ローカルあり  " Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE840;" Foreground="SeaGreen" VerticalAlignment="Center"/>
                        <TextBlock Text=" 常に保持" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <!-- カラム表示: 独立した浮遊カード (背景をこのカード1枚に統一し、開いている列と余白の色差を無くす) -->
            <Border x:Name="ColumnsCard" Margin="6,0,6,4" CornerRadius="12" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1"
                    Effect="{DynamicResource CardShadowBelow}">
            <!-- 角丸クリップはカードではなく中身に掛ける (カードに掛けると外側の影ごと切られて消える) -->
            <ScrollViewer x:Name="ColumnsScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Background="Transparent" PreviewMouseWheel="Columns_PreviewMouseWheel"
                          SizeChanged="ColumnsCard_SizeChanged">
                <ItemsControl x:Name="ColumnsHost" ItemsSource="{Binding ActiveTab.Columns}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:ColumnModel}">
                            <!-- 幅はモデル側で決める: 最終列だけファイル名に合わせて自動調整 (上限あり)、
                                 それ以外は既定幅。検索列の広め既定値もモデルが持つ -->
                            <Border Loaded="Column_Loaded" SizeChanged="Column_SizeChanged"
                                    Width="{Binding Width, Mode=OneWay}"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="0,0,1,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- 検索結果列のヘッダー: この列が検索結果であることを示す -->
                                    <Border Grid.Row="0" Visibility="{Binding IsSearch, Converter={StaticResource B2V}}"
                                            Background="{DynamicResource AccentFocusBrush}" CornerRadius="8"
                                            Margin="5,5,5,2" Padding="9,5">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left" FontFamily="{StaticResource IconFont}" FontSize="12"
                                                       Text="&#xE721;" Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding SearchQuery, StringFormat='「{0}」の検索結果'}"/>
                                        </DockPanel>
                                    </Border>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding Items}"
                                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             SelectionMode="Extended"
                                             TextSearch.TextPath="Name"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Standard"
                                             AllowDrop="True"
                                             SelectionChanged="Column_SelectionChanged"
                                             PreviewKeyDown="Column_PreviewKeyDown"
                                             MouseDoubleClick="Column_MouseDoubleClick"
                                             PreviewMouseLeftButtonDown="Column_PreviewMouseLeftButtonDown"
                                             PreviewMouseLeftButtonUp="Column_PreviewMouseLeftButtonUp"
                                             PreviewMouseMove="Column_PreviewMouseMove"
                                             PreviewMouseRightButtonUp="Column_PreviewMouseRightButtonUp"
                                             DragOver="Column_DragOver"
                                             DragLeave="Column_DragLeave"
                                             Drop="Column_Drop"
                                             ItemTemplateSelector="{StaticResource ColumnItemSelector}">
                                    </ListBox>
                                    <TextBlock Grid.Row="1" Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="このフォルダは空です"/>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Items.Count}" Value="0"/>
                                                            <Condition Binding="{Binding Error}" Value="{x:Null}"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                    <DataTrigger Binding="{Binding IsSearch}" Value="True">
                                                        <Setter Property="Text" Value="一致する項目はありません"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSearchRunning}" Value="True">
                                                        <Setter Property="Text" Value="検索中…"/>
                                                    </DataTrigger>
                                                    <!-- 初回読み込みが終わるまでは「空です」ではなく読み込み中を出す -->
                                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                        <Setter Property="Text" Value="読み込み中…"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Row="1" Text="{Binding Error}" Margin="10" TextWrapping="Wrap"
                                               Foreground="#FFC04040" VerticalAlignment="Top">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </Border>
        </DockPanel>
    </Border>
</Window>
