<Window x:Class="ColumnView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ColumnView"
        Title="Column View"
        Height="680" Width="1180"
        FontFamily="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}" FontSize="13"
        WindowStyle="None"
        Background="Transparent"
        StateChanged="Window_StateChanged"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseMove="Window_PreviewMouseMove">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>

        <!-- ツールバーのアイコンボタン -->
        <Style x:Key="ToolButton" TargetType="ButtonBase">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FF1B1B1B"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#16000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FFBDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleToolButton" TargetType="ToggleButton" BasedOn="{StaticResource ToolButton}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#280078D4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- キャプション (最小化/最大化/閉じる) ボタン -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF202020"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#14000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- タブ (ブラウザー風) -->
        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="2,6,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="8,8,0,0" Background="Transparent"
                                Padding="11,7" MinWidth="130" MaxWidth="220">
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right" Width="18" Height="18" Margin="6,0,0,0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        FontFamily="Segoe MDL2 Assets" FontSize="9" Content="&#xE711;"
                                        Foreground="#FF606060"
                                        ToolTip="タブを閉じる (Ctrl+W)"
                                        Click="CloseTab_Click" Tag="{Binding}"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#60FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 通常のファイル / フォルダー行 (ホーム列のお気に入り・グループメンバーも含む) -->
        <DataTemplate x:Key="FileItemTemplate" DataType="{x:Type local:FileSystemItem}">
            <Grid ToolTipService.ShowDuration="30000"
                  ToolTipOpening="Item_ToolTipOpening"
                  ToolTipClosing="Item_ToolTipClosing">
                <Grid.ToolTip>
                    <ToolTip MaxWidth="420">
                        <Grid Margin="3,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.Resources>
                                <Style TargetType="TextBlock" x:Key="Label">
                                    <Setter Property="Foreground" Value="#FF707070"/>
                                    <Setter Property="Margin" Value="0,1,12,1"/>
                                </Style>
                                <Style TargetType="TextBlock" x:Key="Value">
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </Grid.Resources>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名前" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Style="{StaticResource Value}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="種類" Style="{StaticResource Label}"
                                       Visibility="{Binding TypeRowVisibility}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TypeName}" Style="{StaticResource Value}"
                                       Visibility="{Binding TypeRowVisibility}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="サイズ" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SizeText}" Style="{StaticResource Value}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="更新日時" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ModifiedText}" Style="{StaticResource Value}"/>
                        </Grid>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="14"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Width="16" Height="16"
                       Source="{Binding Icon}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Name}"
                           Margin="4,0,0,0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" FontFamily="Segoe MDL2 Assets" FontSize="11"
                           Text="{Binding Badge}" Foreground="{Binding BadgeBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" FontFamily="Segoe MDL2 Assets" FontSize="9"
                           Text="&#xE76C;" Foreground="#FFB0B0B6"
                           Visibility="{Binding ChevronVisibility}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </DataTemplate>

        <!-- タブグループの見出し行 (クリックで中身を次の列に展開) -->
        <DataTemplate x:Key="GroupItemTemplate" DataType="{x:Type local:FileSystemItem}">
            <Grid Background="Transparent"
                  ToolTip="クリックで中身を開く / 右クリックで「すべてタブで開く」など管理">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Text="&#xE71D;" Foreground="#FF6B5BD2"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                           Margin="4,0,0,0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" Text="{Binding MemberCount}" Foreground="#FF9090A0"
                           Margin="2,0,4,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" FontFamily="Segoe MDL2 Assets" FontSize="9"
                           Text="&#xE76C;" Foreground="#FFB0B0B6"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </DataTemplate>

        <local:ColumnItemTemplateSelector x:Key="ColumnItemSelector"
                                          NormalTemplate="{StaticResource FileItemTemplate}"
                                          GroupTemplate="{StaticResource GroupItemTemplate}"/>

        <!-- パンくずの各セグメント -->
        <Style x:Key="CrumbButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Foreground" Value="#FF1B1B1B"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ルート枠 (WindowStyle=None のため自前で薄い枠) -->
    <Border x:Name="RootBorder" Background="#FFF3F3F3" BorderBrush="#FF9AA0A6" BorderThickness="1">
        <DockPanel x:Name="RootDock">

            <!-- 最上段: タブ列 + キャプションボタン (Chrome 風) -->
            <Grid x:Name="CaptionBar" DockPanel.Dock="Top" Height="40" Background="#FFDDE1E6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <ListBox x:Name="TabStrip" ItemsSource="{Binding Tabs}" SelectedItem="{Binding ActiveTab}"
                             ItemContainerStyle="{StaticResource TabItemStyle}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"
                             PreviewMouseLeftButtonUp="TabStrip_PreviewMouseLeftButtonUp">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                    <Button Style="{StaticResource ToolButton}" Width="32" Height="28" Margin="4,7,0,0"
                            VerticalAlignment="Top" Content="&#xE710;"
                            ToolTip="新しいタブ (Ctrl+T)" Click="NewTab_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Style="{StaticResource CaptionButton}" Content="&#xE921;"
                            ToolTip="最小化" Click="Minimize_Click"/>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Content="&#xE922;"
                            ToolTip="最大化" Click="Maximize_Click"/>
                    <Button Style="{StaticResource CaptionCloseButton}" Content="&#xE8BB;"
                            ToolTip="閉じる" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ツールバー -->
            <Border DockPanel.Dock="Top" Background="White" Padding="8,6"
                    BorderBrush="#FFE0E0E2" BorderThickness="0,0,0,1">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Content="&#xE72B;"
                            ToolTip="戻る (Alt+←)" IsEnabled="{Binding CanGoBack}" Click="Back_Click"/>
                    <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Content="&#xE72A;"
                            ToolTip="進む (Alt+→)" IsEnabled="{Binding CanGoForward}" Click="Forward_Click"/>
                    <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Content="&#xE70E;"
                            ToolTip="上へ (Alt+↑)" IsEnabled="{Binding CanGoUp}" Click="Up_Click"/>
                    <Border DockPanel.Dock="Left" Width="1" Background="#FFE0E0E2" Margin="5,3"/>

                    <!-- 右側のボタン群 -->
                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleToolButton}" Content="&#xE735;"
                                  ToolTip="現在のフォルダーをお気に入りに追加 / 削除"
                                  IsChecked="{Binding IsCurrentFavorite, Mode=OneWay}" Click="Favorite_Click"/>
                    <Button x:Name="GroupsButton" DockPanel.Dock="Right" Style="{StaticResource ToolButton}"
                            Content="&#xE71D;" Foreground="#FF6B5BD2"
                            ToolTip="タブグループ (よく使うフォルダーの組合せをワンクリックで開く)"
                            Click="GroupsButton_Click"/>
                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleToolButton}" Content="&#xED1A;"
                                  ToolTip="隠しファイルを表示 (Ctrl+H)" IsChecked="{Binding ShowHidden}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}"
                            ToolTip="昇順 / 降順の切り替え" Click="SortDirection_Click">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE74B;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SortDescending}" Value="False">
                                                <Setter Property="Text" Value="&#xE74A;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                    <ComboBox DockPanel.Dock="Right" Width="104" Height="30" Margin="4,0"
                              VerticalContentAlignment="Center" ToolTip="並べ替えの基準"
                              SelectedIndex="{Binding SortKeyIndex}">
                        <ComboBoxItem Content="名前"/>
                        <ComboBoxItem Content="更新日時"/>
                        <ComboBoxItem Content="サイズ"/>
                        <ComboBoxItem Content="種類"/>
                    </ComboBox>

                    <!-- アドレスバー: パンくず or 編集テキスト -->
                    <Border x:Name="AddressBar" Margin="4,0" Height="30" Background="White"
                            BorderBrush="#FFCFCFCF" BorderThickness="1" CornerRadius="4"
                            MouseLeftButtonDown="AddressBar_MouseLeftButtonDown">
                        <Grid>
                            <DockPanel>
                                <DockPanel.Style>
                                    <Style TargetType="DockPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditingAddress}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DockPanel.Style>
                                <TextBlock DockPanel.Dock="Left" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Text="&#xE8B7;" Foreground="#FFE3A52E" Margin="8,0,2,0"
                                           VerticalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding Breadcrumbs}" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:Crumb}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                           Foreground="#FFA0A0A6" VerticalAlignment="Center" Margin="1,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFirst}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Button Style="{StaticResource CrumbButton}" Content="{Binding Display}"
                                                        Tag="{Binding}" Click="Crumb_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>

                            <TextBox x:Name="PathBox" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     Visibility="{Binding IsEditingAddress, Converter={StaticResource B2V}}"
                                     Text="{Binding CurrentPath, Mode=OneWay}"
                                     KeyDown="PathBox_KeyDown" LostKeyboardFocus="PathBox_LostFocus"/>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ステータスバー -->
            <StatusBar DockPanel.Dock="Bottom" Background="#FFF8F8F8" BorderBrush="#FFE0E0E2" BorderThickness="0,1,0,0">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}"/>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Space: プレビュー (Seer)   " Foreground="#FF888890"/>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE753;" Foreground="SteelBlue" VerticalAlignment="Center"/>
                        <TextBlock Text=" オンラインのみ  " Foreground="#FF888890"/>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;" Foreground="SeaGreen" VerticalAlignment="Center"/>
                        <TextBlock Text=" ローカルあり  " Foreground="#FF888890"/>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE840;" Foreground="SeaGreen" VerticalAlignment="Center"/>
                        <TextBlock Text=" 常に保持" Foreground="#FF888890"/>
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <!-- カラム表示 -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Background="White">
                <ItemsControl x:Name="ColumnsHost" ItemsSource="{Binding ActiveTab.Columns}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:ColumnModel}">
                            <Border Width="216" BorderBrush="#FFE8E8EA" BorderThickness="0,0,1,0"
                                    Loaded="Column_Loaded">
                                <Grid>
                                    <ListBox ItemsSource="{Binding Items}"
                                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                             BorderThickness="0"
                                             SelectionMode="Extended"
                                             TextSearch.TextPath="Name"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Standard"
                                             AllowDrop="True"
                                             SelectionChanged="Column_SelectionChanged"
                                             PreviewKeyDown="Column_PreviewKeyDown"
                                             MouseDoubleClick="Column_MouseDoubleClick"
                                             PreviewMouseLeftButtonDown="Column_PreviewMouseLeftButtonDown"
                                             PreviewMouseLeftButtonUp="Column_PreviewMouseLeftButtonUp"
                                             PreviewMouseMove="Column_PreviewMouseMove"
                                             PreviewMouseRightButtonUp="Column_PreviewMouseRightButtonUp"
                                             DragOver="Column_DragOver"
                                             DragLeave="Column_DragLeave"
                                             Drop="Column_Drop"
                                             ItemTemplateSelector="{StaticResource ColumnItemSelector}">
                                    </ListBox>
                                    <TextBlock Text="{Binding Error}" Margin="10" TextWrapping="Wrap"
                                               Foreground="#FFC04040" VerticalAlignment="Top">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
